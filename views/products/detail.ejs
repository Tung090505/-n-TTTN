<% layout('layouts/main') %>
    <div class="container mx-auto px-6 py-10">

        <!-- Breadcrumb -->
        <nav class="flex text-sm text-slate-400 mb-8 overflow-x-auto whitespace-nowrap">
            <a href="/" class="hover:text-blue-600">Trang chủ</a>
            <span class="mx-3">/</span>
            <a href="/san-pham?category=<%= product.category %>" class="hover:text-blue-600 uppercase">
                <%= product.category %>
            </a>
            <span class="mx-3">/</span>
            <span class="text-slate-900 font-bold">
                <%= product.name %>
            </span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20">

            <!-- LEFT: IMAGE GALLERY -->
            <div class="lg:col-span-5">
                <div class="glass p-6 rounded-[3rem] sticky top-28">
                    <div class="bg-slate-50 rounded-[2rem] p-8 mb-6 group overflow-hidden">
                        <img src="<%= product.thumbnail %>" alt="<%= product.name %>"
                            class="w-full h-[400px] object-contain transition-transform duration-700 group-hover:scale-110">
                    </div>

                    <!-- Thumbnails -->
                    <div class="grid grid-cols-4 gap-4">
                        <div class="p-2 rounded-2xl border-2 border-blue-600 bg-white cursor-pointer">
                            <img src="<%= product.thumbnail %>" class="w-full h-20 object-contain">
                        </div>
                        <% (product.images || []).forEach(img=> { %>
                            <div
                                class="p-2 rounded-2xl border-2 border-transparent bg-slate-50 hover:border-blue-200 cursor-pointer transition-all">
                                <img src="<%= img.url %>" class="w-full h-20 object-contain">
                            </div>
                            <% }) %>
                    </div>
                </div>
            </div>

            <!-- RIGHT: PRODUCT INFO -->
            <div class="lg:col-span-7">
                <div class="space-y-8 animate-fade-in-up">

                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span
                                class="px-3 py-1 bg-blue-100 text-blue-600 rounded-lg text-xs font-black uppercase tracking-widest">
                                <%= product.brand %>
                            </span>
                            <% if(product.isNewArrival) { %>
                                <span
                                    class="px-3 py-1 bg-indigo-600 text-white rounded-lg text-xs font-black uppercase tracking-widest">MỚI</span>
                                <% } %>
                                    <% if(product.stock> 0) { %>
                                        <span
                                            class="px-3 py-1 bg-emerald-100 text-emerald-600 rounded-lg text-xs font-bold">Còn
                                            hàng</span>
                                        <% } else { %>
                                            <span
                                                class="px-3 py-1 bg-red-100 text-red-600 rounded-lg text-xs font-bold">Hết
                                                hàng</span>
                                            <% } %>
                        </div>
                        <h1 class="text-4xl md:text-5xl font-black text-slate-900 leading-tight mb-4">
                            <%= product.name %>
                        </h1>

                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-2">
                                <div class="flex text-yellow-400">
                                    <% for(let i=1; i<=5; i++) { %>
                                        <span>
                                            <%= i <=Math.round(product.rating) ? '★' : '☆' %>
                                        </span>
                                        <% } %>
                                </div>
                                <span class="text-sm font-bold text-slate-900">
                                    <%= product.rating %>
                                </span>
                                <span class="text-sm text-slate-400">(<%= product.numReviews %> đánh giá)</span>
                            </div>
                            <div class="h-4 w-px bg-slate-200"></div>
                            <span class="text-sm text-slate-500">Đã bán: <span class="font-bold text-slate-800">
                                    <%= product.sold %>
                                </span></span>
                        </div>
                    </div>

                    <div class="p-8 rounded-[2rem] bg-slate-900 text-white relative overflow-hidden shadow-2xl">
                        <div class="absolute top-0 right-0 w-1/3 h-full bg-blue-600/10 blur-[50px]"></div>
                        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div>
                                <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-1">Giá ưu đãi:
                                </p>
                                <div class="flex items-end gap-4">
                                    <span class="text-4xl md:text-5xl font-black text-blue-400">
                                        <%= (product.salePrice || product.price).toLocaleString('vi-VN') %>đ
                                    </span>
                                    <% if(product.salePrice) { %>
                                        <span class="text-xl text-slate-500 line-through mb-1 font-medium">
                                            <%= product.price.toLocaleString('vi-VN') %>đ
                                        </span>
                                        <% } %>
                                </div>
                            </div>
                            <% if(product.salePrice) { %>
                                <div class="px-6 py-2 bg-red-500 rounded-2xl font-black text-sm">GIẢM -<%=
                                        product.discountPercent %>%</div>
                                <% } %>
                        </div>
                    </div>

                    <!-- Short Specs Quick View -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <% let specsObj=product.specifications || {}; while (typeof specsObj==='string' &&
                            specsObj.length> 0) {
                            try {
                            specsObj = JSON.parse(specsObj);
                            if (typeof specsObj !== 'object') break;
                            } catch(e) {
                            specsObj = {};
                            break;
                            }
                            }
                            if (specsObj && typeof specsObj === 'object' && Object.keys(specsObj).length > 0) {
                            const keys = Object.keys(specsObj);
                            if (keys.every(k => !isNaN(k)) && specsObj['0'] === '{') {
                            try {
                            specsObj = JSON.parse(keys.sort((a,b) => a-b).map(k => specsObj[k]).join(''));
                            } catch(e) {}
                            }
                            }
                            const quickSpecs = Object.entries(specsObj).slice(0, 4);
                            %>
                            <% quickSpecs.forEach(([key, val])=> { %>
                                <div class="p-4 rounded-2xl bg-white border border-slate-100">
                                    <p class="text-[10px] text-slate-400 uppercase font-black mb-1">
                                        <%= key %>
                                    </p>
                                    <p class="text-sm font-bold text-slate-800 truncate">
                                        <%= typeof val==='object' ? JSON.stringify(val) : val %>
                                    </p>
                                </div>
                                <% }) %>
                    </div>

                    <!-- Add to cart -->
                    <div class="flex flex-col sm:flex-row gap-4 pt-6">
                        <div class="flex items-center bg-slate-100 rounded-2xl p-1 w-fit">
                            <button onclick="changeQty(-1)"
                                class="w-12 h-12 rounded-xl hover:bg-white transition-colors text-xl font-bold">-</button>
                            <input type="number" id="buy-qty" value="1" min="1" max="<%= product.stock %>"
                                class="w-16 bg-transparent text-center font-black outline-none border-none">
                            <button onclick="changeQty(1)"
                                class="w-12 h-12 rounded-xl hover:bg-white transition-colors text-xl font-bold">+</button>
                        </div>
                        <button onclick="addToCartDetailed()"
                            class="flex-1 py-5 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl shadow-xl shadow-blue-500/25 transition-all text-lg flex items-center justify-center gap-3">
                            <span>🛒 Thêm vào giỏ hàng</span>
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <!-- TABS: SPECS / DESCRIPTION / REVIEWS -->
        <section class="mb-20">
            <div class="flex gap-10 border-b border-slate-100 mb-10 overflow-x-auto">
                <button onclick="switchTab('specs')" data-tab="specs"
                    class="tab-btn pb-6 text-lg font-bold text-blue-600 border-b-4 border-blue-600 transition-all">Thông
                    số kỹ thuật</button>
                <button onclick="switchTab('description')" data-tab="description"
                    class="tab-btn pb-6 text-lg font-bold text-slate-400 hover:text-slate-600 transition-all">Mô tả sản
                    phẩm</button>
                <button onclick="switchTab('reviews')" data-tab="reviews"
                    class="tab-btn pb-6 text-lg font-bold text-slate-400 hover:text-slate-600 transition-all">Đánh giá (
                    <%= product.numReviews %>)
                </button>
            </div>

            <!-- Tab Content -->
            <div id="specs-tab" class="tab-pane">
                <div class="glass p-10 rounded-[3rem]">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-6">
                        <% let fullSpecsObj=product.specifications || {}; while (typeof fullSpecsObj==='string' &&
                            fullSpecsObj.length> 0) {
                            try {
                            fullSpecsObj = JSON.parse(fullSpecsObj);
                            if (typeof fullSpecsObj !== 'object') break;
                            } catch(e) {
                            fullSpecsObj = {};
                            break;
                            }
                            }
                            if (fullSpecsObj && typeof fullSpecsObj === 'object' && Object.keys(fullSpecsObj).length >
                            0) {
                            const keys = Object.keys(fullSpecsObj);
                            if (keys.every(k => !isNaN(k)) && fullSpecsObj['0'] === '{') {
                            try {
                            fullSpecsObj = JSON.parse(keys.sort((a,b) => a-b).map(k => fullSpecsObj[k]).join(''));
                            } catch(e) {}
                            }
                            }
                            %>
                            <% Object.entries(fullSpecsObj).forEach(([key, val])=> { %>
                                <div class="flex items-center justify-between py-4 border-b border-slate-100">
                                    <span class="text-slate-500 font-medium uppercase text-xs tracking-wider">
                                        <%= key %>
                                    </span>
                                    <span class="text-slate-900 font-bold text-right ml-4">
                                        <%= typeof val==='object' ? JSON.stringify(val) : val %>
                                    </span>
                                </div>
                                <% }) %>
                    </div>
                </div>
            </div>

            <div id="description-tab" class="tab-pane hidden">
                <div class="glass p-10 rounded-[3rem] prose prose-slate max-w-none">
                    <%- product.description %>
                </div>
            </div>

            <div id="reviews-tab" class="tab-pane hidden">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
                    <div class="lg:col-span-1">
                        <div class="glass p-8 rounded-[2.5rem] text-center">
                            <h3 class="text-xs font-black uppercase tracking-[3px] text-slate-400 mb-4">Đánh giá trung
                                bình</h3>
                            <p class="text-6xl font-black text-slate-900 mb-2">
                                <%= product.rating %>
                            </p>
                            <div class="flex justify-center text-xl text-yellow-400 mb-4">
                                <% for(let i=1; i<=5; i++) { %>
                                    <span>
                                        <%= i <=product.rating ? '★' : '☆' %>
                                    </span>
                                    <% } %>
                            </div>
                            <p class="text-sm text-slate-500 font-bold">
                                <%= product.numReviews %> nhận xét
                            </p>
                        </div>

                        <% if (user) { %>
                            <div class="glass p-8 rounded-[2.5rem] mt-6">
                                <h4 class="font-bold mb-4 text-slate-900">Viết đánh giá</h4>
                                <form id="review-form" class="space-y-4">
                                    <div class="flex gap-2 text-2xl text-slate-300" id="star-rating">
                                        <% for(let i=1; i<=5; i++) { %>
                                            <button type="button"
                                                class="star-btn hover:text-yellow-400 transition-colors"
                                                data-val="<%= i %>">★</button>
                                            <% } %>
                                    </div>
                                    <input type="hidden" name="rating" id="review-rating" value="5">
                                    <input type="text" name="title" placeholder="Tiêu đề ngắn gọn" required
                                        class="w-full px-4 py-3 rounded-xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 text-sm">
                                    <textarea name="comment" rows="3" placeholder="Chia sẻ cảm nhận..." required
                                        class="w-full px-4 py-3 rounded-xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 text-sm"></textarea>
                                    <button type="submit"
                                        class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/20 active:scale-95 transition-all text-sm">Gửi
                                        đánh giá</button>
                                </form>
                            </div>
                            <% } %>
                    </div>

                    <div class="lg:col-span-2 space-y-6">
                        <% if (product.reviews && product.reviews.length> 0) { %>
                            <% product.reviews.reverse().forEach(review=> { %>
                                <div class="glass p-8 rounded-[2.5rem]">
                                    <div class="flex justify-between items-start mb-4">
                                        <div class="flex items-center gap-4">
                                            <div
                                                class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center font-bold text-slate-500">
                                                <%= review.userName.charAt(0) %>
                                            </div>
                                            <div>
                                                <p class="font-bold text-slate-900 text-sm">
                                                    <%= review.userName %>
                                                </p>
                                                <div class="flex text-xs text-yellow-400">
                                                    <% for(let i=1; i<=5; i++) { %>
                                                        <span>
                                                            <%= i <=review.rating ? '★' : '☆' %>
                                                        </span>
                                                        <% } %>
                                                </div>
                                            </div>
                                        </div>
                                        <span class="text-[10px] text-slate-400 font-black uppercase">
                                            <%= new Date(review.createdAt).toLocaleDateString('vi-VN') %>
                                        </span>
                                    </div>
                                    <h5 class="font-bold text-slate-800 mb-2 truncate">
                                        <%= review.title %>
                                    </h5>
                                    <p class="text-sm text-slate-600 leading-relaxed">
                                        <%= review.comment %>
                                    </p>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div
                                            class="text-center py-20 bg-slate-50/50 rounded-[3rem] border-2 border-dashed border-slate-100">
                                            <p class="text-slate-400 font-bold">Chưa có đánh giá nào cho sản phẩm này.
                                            </p>
                                        </div>
                                        <% } %>
                    </div>
                </div>
            </div>
        </section>

        <!-- RELATED PRODUCTS -->
        <section>
            <h2 class="text-3xl font-black mb-10">Sản phẩm tương tự</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                <% relatedProducts.forEach(p=> { %>
                    <article
                        class="product-card bg-white rounded-3xl p-6 border border-slate-100 shadow-sm relative flex flex-col">
                        <a href="/san-pham/<%= p.slug %>" class="block mb-6 rounded-2xl bg-slate-50 p-4">
                            <img src="<%= p.thumbnail %>" class="w-full h-40 object-contain">
                        </a>
                        <h3 class="font-bold text-slate-900 leading-snug mb-3 line-clamp-2 min-h-[3rem]">
                            <a href="/san-pham/<%= p.slug %>">
                                <%= p.name %>
                            </a>
                        </h3>
                        <div class="mt-auto">
                            <p class="text-blue-600 font-black text-lg">
                                <%= (p.salePrice || p.price).toLocaleString('vi-VN') %>đ
                            </p>
                        </div>
                    </article>
                    <% }) %>
            </div>
        </section>

    </div>

    <script>
        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(t => {
                t.classList.remove('text-blue-600', 'border-blue-600', 'border-b-4');
                t.classList.add('text-slate-400');
            });
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
            const btn = document.querySelector(`[data-tab="${tabId}"]`);
            if (btn) {
                btn.classList.add('text-blue-600', 'border-blue-600', 'border-b-4');
                btn.classList.remove('text-slate-400');
            }
            document.getElementById(`${tabId}-tab`).classList.remove('hidden');
        }

        function changeQty(amt) {
            const input = document.getElementById('buy-qty');
            let val = parseInt(input.value) + amt;
            if (val < 1) val = 1;
            const stock = parseInt('<%= product.stock %>');
            if (val > stock) val = stock;
            input.value = val;
        }

        async function addToCartDetailed() {
            const qty = document.getElementById('buy-qty').value;
            try {
                const res = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: '<%= product._id %>', quantity: parseInt(qty) })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Đã thêm sản phẩm vào giỏ hàng! ⚡', 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Vui lòng đăng nhập!', 'error');
                }
            } catch (err) { showToast('Lỗi thêm vào giỏ hàng', 'error'); }
        }

        document.querySelectorAll('.star-btn').forEach(star => {
            star.addEventListener('click', () => {
                const val = star.getAttribute('data-val');
                document.getElementById('review-rating').value = val;
                document.querySelectorAll('.star-btn').forEach(s => {
                    if (parseInt(s.getAttribute('data-val')) <= val) {
                        s.classList.add('text-yellow-400');
                        s.classList.remove('text-slate-300');
                    } else {
                        s.classList.remove('text-yellow-400');
                        s.classList.add('text-slate-300');
                    }
                });
            });
        });

        const reviewForm = document.getElementById('review-form');
        if (reviewForm) {
            reviewForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(e.target);
                const data = Object.fromEntries(formData.entries());
                try {
                    const res = await fetch('/api/products/<%= product._id %>/reviews', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await res.json();
                    if (result.success) {
                        showToast('Cảm ơn bạn đã đánh giá! ✨', 'success');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        showToast(result.message, 'error');
                    }
                } catch (err) { showToast('Lỗi gửi đánh giá', 'error'); }
            });
        }
    </script>