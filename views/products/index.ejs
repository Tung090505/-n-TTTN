<% layout('layouts/main') %>
    <div class="container mx-auto px-6 py-10">
        <div class="flex flex-col lg:flex-row gap-10">

            <!-- SIDEBAR: FILTERS -->
            <aside class="w-full lg:w-72 space-y-8">
                <div class="glass p-6 rounded-[2rem] sticky top-28">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-xl font-bold">Bộ Lọc</h2>
                        <a href="/san-pham" class="text-xs text-blue-600 hover:underline">Xóa tất cả</a>
                    </div>

                    <form action="/san-pham" method="GET" id="filter-form" class="space-y-8">
                        <!-- Tìm kiếm (Mobile) -->
                        <div class="lg:hidden">
                            <input type="text" name="search" placeholder="Tìm kiếm..."
                                class="w-full px-4 py-2 rounded-xl bg-slate-100 border-none outline-none text-sm">
                        </div>

                        <!-- Danh mục -->
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 mb-4 uppercase tracking-wider">Danh mục</h3>
                            <div class="space-y-3">
                                <% const categories=['laptop', 'cpu' , 'gpu' , 'ram' , 'storage' , 'monitor'
                                    , 'keyboard' , 'mouse' ] %>
                                    <% categories.forEach(cat=> { %>
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="radio" name="category" value="<%= cat %>"
                                                class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-500"
                                                <%=query.category===cat ? 'checked' : '' %>>
                                            <span
                                                class="text-sm text-slate-600 group-hover:text-blue-600 transition-colors uppercase">
                                                <%= cat %>
                                            </span>
                                        </label>
                                        <% }) %>
                            </div>
                        </div>

                        <div class="h-px bg-slate-100"></div>

                        <!-- Thương hiệu -->
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 mb-4 uppercase tracking-wider">Thương hiệu</h3>
                            <div class="grid grid-cols-2 gap-2">
                                <% const brands=['ASUS', 'MSI' , 'Intel' , 'AMD' , 'Gigabyte' , 'Corsair' , 'Kingston' ]
                                    %>
                                    <% brands.forEach(brand=> { %>
                                        <label
                                            class="px-3 py-2 rounded-xl border border-slate-100 text-[11px] font-bold text-slate-500 cursor-pointer text-center hover:bg-blue-50 hover:border-blue-200 transition-all peer-checked:bg-blue-600 peer-checked:text-white">
                                            <input type="checkbox" name="brand" value="<%= brand %>" class="hidden peer"
                                                <%=query.brand && query.brand.includes(brand) ? 'checked' : '' %>>
                                            <%= brand %>
                                        </label>
                                        <% }) %>
                            </div>
                        </div>

                        <div class="h-px bg-slate-100"></div>

                        <!-- Khoảng giá -->
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 mb-4 uppercase tracking-wider">Khoảng giá (VNĐ)
                            </h3>
                            <div class="space-y-4">
                                <div>
                                    <label class="text-[10px] text-slate-400 font-bold uppercase">Từ</label>
                                    <input type="number" name="price[gte]" value="<%= query.price?.gte %>"
                                        placeholder="0"
                                        class="w-full px-4 py-2 rounded-xl bg-slate-50 border-none outline-none text-sm">
                                </div>
                                <div>
                                    <label class="text-[10px] text-slate-400 font-bold uppercase">Đến</label>
                                    <input type="number" name="price[lte]" value="<%= query.price?.lte %>"
                                        placeholder="99.000.000"
                                        class="w-full px-4 py-2 rounded-xl bg-slate-50 border-none outline-none text-sm">
                                </div>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg shadow-blue-500/20 transition-all">
                            Áp Dụng
                        </button>
                    </form>
                </div>
            </aside>

            <!-- CONTENT: PRODUCTS GRID -->
            <main class="flex-1">
                <!-- Top Bar -->
                <div class="flex flex-col sm:flex-row items-center justify-between mb-8 gap-4">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900">
                            <% if (query.search) { %>
                                Tìm kiếm: <span class="text-blue-600">"<%= query.search %>"</span>
                                <% } else { %>
                                    Danh mục: <span class="text-blue-600 uppercase">
                                        <%= query.category || 'Tất cả sản phẩm' %>
                                    </span>
                                    <% } %>
                        </h1>
                        <p class="text-sm text-slate-500">Tìm thấy <span class="font-bold text-slate-800">
                                <%= total %>
                            </span> kết quả</p>
                    </div>

                    <div class="flex items-center gap-4">
                        <label class="text-sm font-medium text-slate-400">Sắp xếp:</label>
                        <select name="sort" form="filter-form" onchange="this.form.submit()"
                            class="bg-white border border-slate-100 rounded-xl px-4 py-2 text-sm font-bold outline-none focus:ring-2 focus:ring-blue-500/20 shadow-sm transition-all">
                            <option value="-createdAt" <%=query.sort==='-createdAt' ? 'selected' : '' %>>Mới nhất
                            </option>
                            <option value="price" <%=query.sort==='price' ? 'selected' : '' %>>Giá thấp đến cao</option>
                            <option value="-price" <%=query.sort==='-price' ? 'selected' : '' %>>Giá cao đến thấp
                            </option>
                            <option value="-sold" <%=query.sort==='-sold' ? 'selected' : '' %>>Bán chạy nhất</option>
                        </select>
                    </div>
                </div>

                <!-- Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8">
                    <% if (products.length===0) { %>
                        <div class="col-span-full py-20 text-center">
                            <div class="text-6xl mb-4">🔍</div>
                            <h2 class="text-xl font-bold text-slate-600">Rất tiếc, không tìm thấy sản phẩm phù hợp.</h2>
                            <a href="/san-pham" class="text-blue-600 hover:underline mt-2 inline-block">Xem tất cả sản
                                phẩm</a>
                        </div>
                        <% } %>

                            <% products.forEach(p=> { %>
                                <article
                                    class="product-card group bg-white rounded-3xl p-6 border border-slate-100 shadow-sm relative flex flex-col">
                                    <a href="/san-pham/<%= p.slug %>"
                                        class="block mb-6 overflow-hidden rounded-2xl bg-slate-50 p-4">
                                        <img src="<%= p.thumbnail %>" alt="<%= p.name %>"
                                            class="w-full h-48 object-contain mix-blend-multiply group-hover:scale-110 transition-transform duration-500">
                                    </a>

                                    <div class="flex-grow">
                                        <div class="flex items-center gap-2 mb-2">
                                            <span
                                                class="px-2 py-0.5 rounded-md bg-slate-100 text-[10px] font-bold text-slate-500 uppercase tracking-wider">
                                                <%= p.brand %>
                                            </span>
                                            <% if(p.isNewArrival) { %>
                                                <span
                                                    class="px-2 py-0.5 rounded-md badge-new text-[10px] font-bold text-white uppercase tracking-wider">MỚI</span>
                                                <% } %>
                                        </div>
                                        <h3
                                            class="font-bold text-slate-900 leading-snug mb-3 group-hover:text-blue-600 transition-colors line-clamp-2 min-h-[3rem]">
                                            <a href="/san-pham/<%= p.slug %>">
                                                <%= p.name %>
                                            </a>
                                        </h3>
                                    </div>

                                    <div
                                        class="flex items-center justify-between pt-4 border-t border-slate-50 mt-auto">
                                        <div>
                                            <p class="text-blue-600 font-extrabold text-xl font-heading">
                                                <%= (p.salePrice || p.price).toLocaleString('vi-VN') %>đ
                                            </p>
                                            <% if(p.salePrice) { %>
                                                <p class="text-slate-400 line-through text-xs font-medium">
                                                    <%= p.price.toLocaleString('vi-VN') %>đ
                                                </p>
                                                <% } %>
                                        </div>
                                        <button onclick="addToCart('<%= p._id %>')"
                                            class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center hover:bg-blue-600 transition-all shadow-md active:scale-95">
                                            🛒
                                        </button>
                                    </div>
                                </article>
                                <% }) %>
                </div>

                <!-- Pagination -->
                <% if (totalPages> 1) { %>
                    <div class="mt-12 flex justify-center gap-2">
                        <% for(let i=1; i<=totalPages; i++) { %>
                            <a href="/san-pham?page=<%= i %><%= query.category ? '&category='+query.category : '' %><%= query.brand ? '&brand='+query.brand : '' %><%= query.sort ? '&sort='+query.sort : '' %>"
                                class="w-12 h-12 flex items-center justify-center rounded-xl font-bold transition-all <%= currentPage === i ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/20' : 'bg-white text-slate-600 hover:bg-slate-100' %>">
                                <%= i %>
                            </a>
                            <% } %>
                    </div>
                    <% } %>
            </main>
        </div>
    </div>

    <script>
        async function addToCart(id) {
            try {
                const res = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: id, quantity: 1 })
                });
                const data = await res.json();
                if (data.success) {
                    alert('Đã thêm sản phẩm vào giỏ hàng! ⚡');
                    window.location.reload();
                } else {
                    alert(data.message || 'Lỗi! Vui lòng thử lại.');
                }
            } catch (err) { console.error(err); }
        }
    </script>