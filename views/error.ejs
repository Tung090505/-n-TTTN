<!-- Trang lỗi -->
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %> | TechStore
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    <div class="text-center">
        <h1 class="text-8xl font-extrabold text-blue-600">
            <%= statusCode %>
        </h1>
        <p class="text-2xl text-gray-700 mt-4 mb-2">
            <%= title %>
        </p>
        <p class="text-gray-500 mb-8">
            <%= message %>
        </p>
        <a href="/" class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700">
            ← Về trang chủ
        </a>
    </div>
</body>

</html>