<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <meta name="description" content="TechStore - Mua laptop, PC, linh kiện máy tính chính hãng giá tốt nhất">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <!-- CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">

  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    h1,
    h2,
    h3,
    .font-heading {
      font-family: 'Outfit', sans-serif;
    }

    .text-gradient {
      background: linear-gradient(to right, #3b82f6, #6366f1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-slate-50 min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>

    <main class="flex-grow">
      <%- body %>
    </main>

    <%- include('../partials/footer') %>

      <!-- Global Notification System -->
      <div id="toast-container" class="fixed top-24 right-6 z-[9999] flex flex-col gap-4 max-w-sm w-full"></div>

      <script>
        function showToast(message, type = 'success') {
          const container = document.getElementById('toast-container');
          const toast = document.createElement('div');

          const bgColor = type === 'success' ? 'bg-emerald-500' : 'bg-red-500';
          const icon = type === 'success' ? '✅' : '❌';

          toast.className = `${bgColor} text-white p-5 rounded-2xl shadow-2xl flex items-start gap-4 animate-fade-in-right transform transition-all duration-300`;
          toast.innerHTML = `
                <div class="text-xl">${icon}</div>
                <div class="flex-1">
                    <p class="text-xs font-black uppercase tracking-widest opacity-70 mb-1">${type === 'success' ? 'Thành công' : 'Lỗi hệ thống'}</p>
                    <p class="text-sm font-bold leading-tight">${message}</p>
                </div>
            `;

          container.appendChild(toast);

          // Auto remove
          setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-x-full');
            setTimeout(() => toast.remove(), 300);
          }, 5000);
        }

        // Handle flash messages
        <% if (locals.success) { %>
          showToast("<%= success %>", 'success');
        <% } %>
        <% if (locals.error) { %>
          showToast("<%= error %>", 'error');
        <% } %>

        // Check for specific query params (like registration success)
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('registered')) {
          showToast('Đăng ký thành công! Chào mừng bạn gia nhập TechStore. ✨', 'success');
        }
      </script>
</body>

</html>