<% layout('layouts/main') %>

    <div class="container mx-auto px-6 py-10">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- SIDEBAR -->
            <%- include('../../partials/admin-sidebar', { active: 'products' }) %>

                <!-- MAIN CONTENT -->
                <main class="flex-1">
                    <div class="glass p-10 rounded-[3rem] shadow-xl">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
                            <h2 class="text-3xl font-black text-slate-900">Danh Mục Sản Phẩm</h2>
                            <a href="/admin/san-pham/them"
                                class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all shadow-lg shadow-blue-500/25">
                                + Thêm Sản Phẩm Mới
                            </a>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr
                                        class="text-xs font-black uppercase tracking-widest text-slate-400 border-b border-slate-100">
                                        <th class="pb-6">Sản phẩm</th>
                                        <th class="pb-6">Danh mục</th>
                                        <th class="pb-6">Giá</th>
                                        <th class="pb-6">Kho</th>
                                        <th class="pb-6">Trạng thái</th>
                                        <th class="pb-6 text-right">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-50">
                                    <% products.forEach(p=> { %>
                                        <tr class="group hover:bg-slate-50/50 transition-colors">
                                            <td class="py-6">
                                                <div class="flex items-center gap-4">
                                                    <div
                                                        class="w-14 h-14 bg-white rounded-xl p-2 border border-slate-100 shadow-sm shrink-0">
                                                        <img src="<%= p.thumbnail %>"
                                                            class="w-full h-full object-contain">
                                                    </div>
                                                    <div>
                                                        <p class="font-bold text-slate-900 line-clamp-1">
                                                            <%= p.name %>
                                                        </p>
                                                        <p class="text-[10px] text-slate-400 font-black uppercase">
                                                            <%= p.brand %>
                                                        </p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-6">
                                                <span
                                                    class="px-3 py-1 bg-slate-100 rounded-lg text-[10px] font-black uppercase text-slate-500">
                                                    <%= p.category %>
                                                </span>
                                            </td>
                                            <td class="py-6">
                                                <p class="text-sm font-black text-blue-600">
                                                    <%= p.salePrice ? p.salePrice.toLocaleString('vi-VN') :
                                                        p.price.toLocaleString('vi-VN') %>đ
                                                </p>
                                            </td>
                                            <td class="py-6 font-bold text-slate-700">
                                                <%= p.stock %>
                                            </td>
                                            <td class="py-6">
                                                <% if(p.isActive) { %>
                                                    <span
                                                        class="w-3 h-3 rounded-full bg-emerald-500 inline-block ring-4 ring-emerald-100"></span>
                                                    <% } else { %>
                                                        <span
                                                            class="w-3 h-3 rounded-full bg-slate-300 inline-block ring-4 ring-slate-100"></span>
                                                        <% } %>
                                            </td>
                                            <td class="py-6 text-right">
                                                <div class="flex justify-end gap-2">
                                                    <a href="/admin/san-pham/sua/<%= p._id %>"
                                                        class="w-9 h-9 flex items-center justify-center bg-white border border-slate-200 rounded-lg hover:border-blue-500 hover:text-blue-500 transition-all shadow-sm">✏️</a>
                                                    <button onclick="deleteProduct('<%= p._id %>')"
                                                        class="w-9 h-9 flex items-center justify-center bg-white border border-slate-200 rounded-lg hover:border-red-500 hover:text-red-500 transition-all shadow-sm text-xs">🗑️</button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </main>
        </div>
    </div>

    <script>
        async function deleteProduct(id) {
            if (!confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) return;
            try {
                const res = await fetch(`/api/products/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    showToast('Đã xóa thành công!', 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message, 'error');
                }
            } catch (err) { showToast('Lỗi xóa sản phẩm', 'error'); }
        }
    </script>