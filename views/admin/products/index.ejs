<% layout('layouts/main') %>

    <div class="container mx-auto px-6 py-10">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- SIDEBAR -->
            <%- include('../../partials/admin-sidebar', { active: 'products' }) %>

                <!-- MAIN CONTENT -->
                <main class="flex-1">
                    <% const catMap={ 'laptop' : 'Laptop' , 'pc' : 'Máy tính bộ (PC)' , 'cpu' : 'Bộ vi xử lý (CPU)'
                        , 'gpu' : 'Card đồ họa (VGA)' , 'ram' : 'Bộ nhớ (RAM)' , 'storage' : 'Ổ cứng (SSD/HDD)'
                        , 'motherboard' : 'Bo mạch chủ' , 'psu' : 'Nguồn máy tính' , 'case' : 'Vỏ máy tính' , 'cooling'
                        : 'Tản nhiệt' , 'monitor' : 'Màn hình' , 'keyboard' : 'Bàn phím' , 'mouse' : 'Chuột máy tính'
                        , 'headset' : 'Tai nghe' }; %>
                        <div class="glass p-10 rounded-[3rem] shadow-xl">
                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
                                <div class="flex flex-col md:flex-row items-baseline gap-4 md:items-center">
                                    <h2 class="text-3xl font-black text-slate-900">Danh Mục Sản Phẩm</h2>
                                    <select id="categoryFilter"
                                        class="px-5 py-3 rounded-2xl bg-white border border-slate-200 text-sm font-bold text-slate-700 outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 cursor-pointer shadow-sm transition-all appearance-none"
                                        style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2364748B%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto; padding-right: 2.5rem;">
                                        <option value="all">🟢 Tất cả danh mục</option>
                                        <% Object.entries(catMap).forEach(([val, label])=> { %>
                                            <option value="<%= val %>">
                                                <%= label %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>
                                <a href="/admin/san-pham/them"
                                    class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all shadow-lg shadow-blue-500/25">
                                    + Thêm Sản Phẩm Mới
                                </a>
                            </div>

                            <div class="overflow-x-auto">
                                <table class="w-full text-left">
                                    <thead>
                                        <tr
                                            class="text-xs font-black uppercase tracking-widest text-slate-400 border-b border-slate-100">
                                            <th class="pb-6">Sản phẩm</th>
                                            <th class="pb-6">Danh mục</th>
                                            <th class="pb-6">Giá</th>
                                            <th class="pb-6">Kho</th>
                                            <th class="pb-6">Trạng thái</th>
                                            <th class="pb-6 text-right">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-50">
                                        <% products.forEach(p=> { %>
                                            <tr data-category="<%= p.category %>"
                                                class="product-row group hover:bg-slate-50/50 transition-colors <%= p.isActive ? '' : 'opacity-60 grayscale-[30%] bg-slate-50/50' %>">
                                                <td class="py-6">
                                                    <div class="flex items-center gap-4">
                                                        <div
                                                            class="w-14 h-14 bg-white rounded-xl p-2 border border-slate-100 shadow-sm shrink-0">
                                                            <img src="<%= p.thumbnail %>"
                                                                class="w-full h-full object-contain">
                                                        </div>
                                                        <div>
                                                            <p
                                                                class="font-bold text-slate-900 line-clamp-1 <%= p.isActive ? '' : 'line-through text-slate-500' %>">
                                                                <%= p.name %>
                                                            </p>
                                                            <p class="text-[10px] text-slate-400 font-black uppercase">
                                                                <%= p.brand %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="py-6">
                                                    <span
                                                        class="px-3 py-1 bg-slate-100 rounded-lg text-[10px] font-black uppercase text-slate-500">
                                                        <%= catMap[p.category] || p.category %>
                                                    </span>
                                                </td>
                                                <td class="py-6">
                                                    <p
                                                        class="text-sm font-black <%= p.isActive ? 'text-blue-600' : 'text-slate-500' %>">
                                                        <%= p.salePrice ? p.salePrice.toLocaleString('vi-VN') :
                                                            p.price.toLocaleString('vi-VN') %>đ
                                                    </p>
                                                </td>
                                                <td class="py-6 font-bold text-slate-700">
                                                    <%= p.stock %>
                                                </td>
                                                <td class="py-6">
                                                    <% if(p.isActive) { %>
                                                        <div class="flex items-center gap-2">
                                                            <span
                                                                class="w-2.5 h-2.5 rounded-full bg-emerald-500 ring-4 ring-emerald-50"></span>
                                                            <span
                                                                class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Đang
                                                                Bán</span>
                                                        </div>
                                                        <% } else { %>
                                                            <div class="flex items-center gap-2">
                                                                <span
                                                                    class="w-2.5 h-2.5 rounded-full bg-red-400 ring-4 ring-red-50"></span>
                                                                <span
                                                                    class="text-[10px] font-black text-red-500 uppercase tracking-widest">Ngưng
                                                                    Bán</span>
                                                            </div>
                                                            <% } %>
                                                </td>
                                                <td class="py-6 text-right">
                                                    <div class="flex justify-end gap-2">
                                                        <a href="/admin/san-pham/sua/<%= p._id %>"
                                                            class="w-9 h-9 flex items-center justify-center bg-white border border-slate-200 rounded-lg hover:border-blue-500 hover:text-blue-500 transition-all shadow-sm">✏️</a>
                                                        <button onclick="deleteProduct('<%= p._id %>')"
                                                            class="w-9 h-9 flex items-center justify-center bg-white border border-slate-200 rounded-lg hover:border-red-500 hover:text-red-500 transition-all shadow-sm text-xs">🗑️</button>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                </main>
        </div>
    </div>

    <script>
        // Category Filter Logic
        document.getElementById('categoryFilter').addEventListener('change', function () {
            const selectedCat = this.value;
            const rows = document.querySelectorAll('tbody tr.product-row');

            rows.forEach(row => {
                if (selectedCat === 'all' || row.dataset.category.toLowerCase() === selectedCat.toLowerCase()) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        async function deleteProduct(id) {
            if (!confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) return;
            try {
                const res = await fetch(`/api/products/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    showToast('Đã xóa thành công!', 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message, 'error');
                }
            } catch (err) { showToast('Lỗi xóa sản phẩm', 'error'); }
        }
    </script>