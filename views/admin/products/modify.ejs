<% layout('layouts/main') %>

    <div class="container mx-auto px-6 py-10">
        <div class="max-w-4xl mx-auto">
            <a href="/admin/san-pham"
                class="text-sm font-bold text-slate-400 hover:text-blue-600 transition-colors flex items-center gap-2 mb-8">
                ← Quay lại danh sách
            </a>

            <div class="glass p-10 md:p-14 rounded-[3rem] shadow-2xl border border-white/40">
                <h2 class="text-4xl font-black text-slate-900 mb-10">
                    <%= product ? 'Cập Nhật Sản Phẩm' : 'Thêm Sản Phẩm Mới' %>
                </h2>

                <form id="productForm" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <!-- Tên sản phẩm -->
                        <div class="md:col-span-2">
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Tên
                                Sản Phẩm</label>
                            <input type="text" name="name" value="<%= product ? product.name : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Danh mục -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Danh
                                Mục</label>
                            <select name="category" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900 appearance-none">
                                <option value="laptop" <%=product && product.category==='laptop' ? 'selected' : '' %>
                                    >Laptop</option>
                                <option value="cpu" <%=product && product.category==='cpu' ? 'selected' : '' %>>CPU
                                </option>
                                <option value="gpu" <%=product && product.category==='gpu' ? 'selected' : '' %>>VGA /
                                    GPU</option>
                                <option value="ram" <%=product && product.category==='ram' ? 'selected' : '' %>>RAM
                                </option>
                                <option value="storage" <%=product && product.category==='storage' ? 'selected' : '' %>
                                    >SSD / HDD</option>
                                <option value="monitor" <%=product && product.category==='monitor' ? 'selected' : '' %>
                                    >Màn hình</option>
                            </select>
                        </div>

                        <!-- Thương hiệu -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Thương
                                Hiệu</label>
                            <input type="text" name="brand" value="<%= product ? product.brand : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Giá gốc -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Giá
                                Gốc (VNĐ)</label>
                            <input type="number" name="price" value="<%= product ? product.price : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Giá khuyến mãi -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Giá
                                Khuyến Mãi (VNĐ)</label>
                            <input type="number" name="salePrice" value="<%= product ? product.salePrice : '' %>"
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Tồn kho -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Số
                                Lượng Tồn Kho</label>
                            <input type="number" name="stock" value="<%= product ? product.stock : 0 %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Thumbnail -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Ảnh
                                Đại Diện (URL)</label>
                            <input type="text" name="thumbnail" value="<%= product ? product.thumbnail : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>
                    </div>

                    <!-- Mô tả ngắn -->
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Mô
                            Tả Ngắn</label>
                        <textarea name="shortDescription" rows="2" required
                            class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900"><%= product ? product.shortDescription : '' %></textarea>
                    </div>

                    <!-- Mô tả chi tiết -->
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Mô
                            Tả Chi Tiết</label>
                        <textarea name="description" rows="5" required
                            class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900"><%= product ? product.description : '' %></textarea>
                    </div>

                    <!-- Thông số kỹ thuật (JSON) -->
                    <div>
                        <label
                            class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Thông
                            Số Kỹ Thuật (JSON)</label>
                        <textarea name="specifications" rows="5"
                            placeholder='{"cores": 8, "threads": 16, "socket": "AM5"}'
                            class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-mono text-xs font-bold text-blue-600"><%= product ? JSON.stringify(product.specifications, null, 2) : '{}' %></textarea>
                        <p class="text-[10px] text-slate-400 mt-2 ml-1 italic">* Nhập đúng định dạng JSON</p>
                    </div>

                    <div class="flex items-center gap-6 pt-6">
                        <button type="submit"
                            class="flex-grow py-5 bg-slate-900 hover:bg-black text-white font-black rounded-[2rem] transition-all transform hover:-translate-y-1 shadow-xl shadow-slate-900/20 active:scale-95">
                            <%= product ? 'Lưu Thay Đổi' : 'Tạo Sản Phẩm' %>
                        </button>
                        <a href="/admin/san-pham"
                            class="px-10 py-5 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-[2rem] transition-all">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('productForm');
        form.onsubmit = async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            // Chuyển đổi specifications string thành object
            try {
                data.specifications = JSON.parse(data.specifications || '{}');
            } catch (e) {
                alert('Định dạng Thông số kỹ thuật (JSON) không hợp lệ!');
                return;
            }

            const url = `<%= product ? '/api/products/' + product._id : '/api/products' %>`;
            const method = `<%= product ? 'PUT' : 'POST' %>`;

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    showToast('Thành công! 🌟', 'success');
                    setTimeout(() => window.location.href = '/admin/san-pham', 1500);
                } else {
                    showToast(result.message, 'error');
                }
            } catch (err) { showToast('Lỗi lưu sản phẩm', 'error'); }
        };
    </script>