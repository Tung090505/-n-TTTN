<% layout('layouts/main') %>

    <div class="container mx-auto px-6 py-10">
        <div class="max-w-4xl mx-auto">
            <a href="/admin/san-pham"
                class="text-sm font-bold text-slate-400 hover:text-blue-600 transition-colors flex items-center gap-2 mb-8">
                ← Quay lại danh sách
            </a>

            <div class="glass p-10 md:p-14 rounded-[3rem] shadow-2xl border border-white/40">
                <h2 class="text-4xl font-black text-slate-900 mb-10">
                    <%= product ? 'Cập Nhật Sản Phẩm' : 'Thêm Sản Phẩm Mới' %>
                </h2>

                <form id="productForm" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <!-- Tên sản phẩm -->
                        <div class="md:col-span-2">
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Tên
                                Sản Phẩm</label>
                            <input type="text" name="name" value="<%= product ? product.name : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Danh mục -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Danh
                                Mục</label>
                            <select name="category" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900 appearance-none">
                                <option value="laptop" <%=product && product.category==='laptop' ? 'selected' : '' %>
                                    >Laptop</option>
                                <option value="cpu" <%=product && product.category==='cpu' ? 'selected' : '' %>>CPU
                                </option>
                                <option value="gpu" <%=product && product.category==='gpu' ? 'selected' : '' %>>VGA /
                                    GPU</option>
                                <option value="ram" <%=product && product.category==='ram' ? 'selected' : '' %>>RAM
                                </option>
                                <option value="storage" <%=product && product.category==='storage' ? 'selected' : '' %>
                                    >SSD / HDD</option>
                                <option value="monitor" <%=product && product.category==='monitor' ? 'selected' : '' %>
                                    >Màn hình</option>
                            </select>
                        </div>

                        <!-- Thương hiệu -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Thương
                                Hiệu</label>
                            <input type="text" name="brand" value="<%= product ? product.brand : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Giá gốc -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Giá
                                Gốc (VNĐ)</label>
                            <input type="number" name="price" value="<%= product ? product.price : '' %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Giá khuyến mãi -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Giá
                                Khuyến Mãi (VNĐ)</label>
                            <input type="number" name="salePrice" value="<%= product ? product.salePrice : '' %>"
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Tồn kho -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Số
                                Lượng Tồn Kho</label>
                            <input type="number" name="stock" value="<%= product ? product.stock : 0 %>" required
                                class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900">
                        </div>

                        <!-- Thumbnail -->
                        <div>
                            <label
                                class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">
                                Ảnh Đại Diện (File hoặc URL)
                            </label>
                            <div class="space-y-4">
                                <!-- Preview Image -->
                                <div class="w-24 h-24 rounded-2xl bg-slate-100 overflow-hidden border border-slate-200">
                                    <img id="imagePreview"
                                        src="<%= product ? product.thumbnail : '/images/default-product.webp' %>"
                                        class="w-full h-full object-cover">
                                </div>
                                <div class="grid grid-cols-1 gap-4">
                                    <input type="file" name="image" id="imageInput" accept="image/*"
                                        class="text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-black file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer">
                                    <input type="text" name="thumbnail" value="<%= product ? product.thumbnail : '' %>"
                                        placeholder="Hoặc dán URL ảnh tại đây"
                                        class="w-full px-6 py-3 rounded-2xl bg-slate-50 border border-slate-100 text-xs font-bold outline-none focus:border-blue-500 transition-all">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Mô tả ngắn -->
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Mô
                            Tả Ngắn</label>
                        <textarea name="shortDescription" rows="2" required
                            class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900"><%= product ? product.shortDescription : '' %></textarea>
                    </div>

                    <!-- Trạng Thái (Kích hoạt / Ngưng bán) -->
                    <div>
                        <label
                            class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Trạng
                            Thái Sẩn Phẩm</label>
                        <select name="isActive"
                            class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900 appearance-none">
                            <option value="true" <%=(product && product.isActive !==false) ? 'selected' : '' %>>🟢 Đang
                                Kinh Doanh</option>
                            <option value="false" <%=(product && product.isActive===false) ? 'selected' : '' %>>🔴 Ngưng
                                Bán / Ẩn Sản Phẩm</option>
                        </select>
                    </div>

                    <!-- Mô tả chi tiết -->
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400 mb-3 ml-1">Mô
                            Tả Chi Tiết</label>
                        <textarea name="description" rows="5" required
                            class="w-full px-8 py-5 rounded-3xl bg-slate-50 border border-slate-100 focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all outline-none font-bold text-slate-900"><%= product ? product.description : '' %></textarea>
                    </div>

                    <!-- Thông số kỹ thuật (Builder) -->
                    <div id="specifications-container">
                        <div class="flex items-center justify-between mb-3 ml-1">
                            <label class="block text-[10px] font-black uppercase tracking-[2px] text-slate-400">Thông Số
                                Kỹ Thuật</label>
                            <button type="button" id="addSpecBtn"
                                class="text-xs font-bold text-blue-600 hover:text-blue-800 transition-colors flex items-center gap-1">+
                                Thêm thông số</button>
                        </div>

                        <div id="specList" class="space-y-3">
                            <!-- Các dòng specs sẽ được render tại đây bằng JS -->
                        </div>

                        <!-- Ẩn thẻ textarea cũ nhưng dùng nó để submit dữ liệu JSON cuối cùng lên server -->
                        <textarea name="specifications" id="hiddenSpecs"
                            class="hidden"><%= product ? JSON.stringify(product.specifications, null, 2) : '{}' %></textarea>
                    </div>

                    <div class="flex items-center gap-6 pt-6">
                        <button type="submit" id="submitBtn"
                            class="flex-grow py-5 bg-slate-900 hover:bg-black text-white font-black rounded-[2rem] transition-all transform hover:-translate-y-1 shadow-xl shadow-slate-900/20 active:scale-95 flex items-center justify-center gap-3">
                            <span id="btnText">
                                <%= product ? 'Lưu Thay Đổi' : 'Tạo Sản Phẩm' %>
                            </span>
                            <div id="loader"
                                class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin">
                            </div>
                        </button>
                        <a href="/admin/san-pham"
                            class="px-10 py-5 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-[2rem] transition-all">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Preview ảnh khi chọn file
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');
        const submitBtn = document.getElementById('submitBtn');
        const loader = document.getElementById('loader');
        const btnText = document.getElementById('btnText');

        imageInput.onchange = evt => {
            const [file] = imageInput.files;
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
            }
        };

        // --- Logic cho dynamic specifications (Đã sửa lỗi không lưu giá trị) ---
        const hiddenSpecs = document.getElementById('hiddenSpecs');
        const specList = document.getElementById('specList');
        const addSpecBtn = document.getElementById('addSpecBtn');

        // Hàm tạo một dòng thông số mới trong DOM
        const createSpecRow = (key = '', val = '') => {
            const row = document.createElement('div');
            row.className = 'flex items-center gap-3 spec-item-row';
            row.innerHTML = `
                <input type="text" placeholder="Tên thông số (VD: ram)" value="${key}" class="spec-key w-1/3 px-4 py-3 rounded-xl bg-white border border-slate-200 text-xs font-bold text-slate-700 outline-none focus:border-blue-500 transition-all">
                <input type="text" placeholder="Giá trị (VD: 16GB)" value="${val}" class="spec-val flex-1 px-4 py-3 rounded-xl bg-white border border-slate-200 text-xs text-slate-700 outline-none focus:border-blue-500 transition-all">
                <button type="button" class="del-spec-btn w-10 h-10 shrink-0 flex items-center justify-center bg-red-50 text-red-500 hover:bg-red-500 hover:text-white rounded-xl transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
            `;

            row.querySelector('.del-spec-btn').onclick = () => row.remove();
            specList.appendChild(row);
        };

        // Lấy dữ liệu ban đầu từ database (ẩn trong textarea)
        let initialSpecs = {};
        try {
            initialSpecs = JSON.parse(hiddenSpecs.value || '{}');
        } catch (e) { initialSpecs = {}; }

        // Render các dòng đã có
        Object.entries(initialSpecs).forEach(([k, v]) => createSpecRow(k, v));

        // Nút thêm dòng mới: Cứ bấm là thêm, không đụng chạm đến data cũ trong DOM
        addSpecBtn.onclick = () => createSpecRow('', '');

        // Hàm thu thập toàn bộ dữ liệu từ các ô input chuyển thành JSON để gửi đi
        const syncSpecsToJson = () => {
            const finalSpecs = {};
            document.querySelectorAll('.spec-item-row').forEach(row => {
                const key = row.querySelector('.spec-key').value.trim();
                const val = row.querySelector('.spec-val').value.trim();
                if (key) finalSpecs[key] = val; // Chỉ lấy những dòng có Tên thông số
            });
            hiddenSpecs.value = JSON.stringify(finalSpecs);
        };
        // ----------------------------------------

        const form = document.getElementById('productForm');
        form.onsubmit = async (e) => {
            e.preventDefault();

            // QUAN TRỌNG: Trước khi gửi đi, phải gộp dữ liệu từ các ô input vào JSON
            syncSpecsToJson();

            // Hiển thị loading
            submitBtn.disabled = true;
            loader.classList.remove('hidden');
            btnText.innerText = 'Đang xử lý...';

            const formData = new FormData(form);

            // Kiểm tra lại valid JSON
            try {
                JSON.parse(formData.get('specifications') || '{}');
            } catch (e) {
                alert('Có lỗi trong khi tạo Thông số kỹ thuật!');
                submitBtn.disabled = false;
                loader.classList.add('hidden');
                btnText.innerText = '<%= product ? "Lưu Thay Đổi" : "Tạo Sản Phẩm" %>';
                return;
            }

            const url = `<%= product ? '/api/products/' + product._id : '/api/products' %>`;
            const method = `<%= product ? 'PUT' : 'POST' %>`;

            try {
                const res = await fetch(url, {
                    method: method,
                    // Không set Content-Type khi gửi FormData, trình duyệt sẽ tự set kèm boundary
                    body: formData
                });
                const result = await res.json();
                if (result.success) {
                    showToast('Thành công! 🌟', 'success');
                    setTimeout(() => window.location.href = '/admin/san-pham', 1500);
                } else {
                    showToast(result.message, 'error');
                    submitBtn.disabled = false;
                    loader.classList.add('hidden');
                    btnText.innerText = '<%= product ? "Lưu Thay Đổi" : "Tạo Sản Phẩm" %>';
                }
            } catch (err) {
                showToast('Lỗi lưu sản phẩm', 'error');
                submitBtn.disabled = false;
                loader.classList.add('hidden');
                btnText.innerText = '<%= product ? "Lưu Thay Đổi" : "Tạo Sản Phẩm" %>';
            }
        };
    </script>