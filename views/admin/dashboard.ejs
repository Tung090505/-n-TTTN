<% layout('layouts/main') %>

    <div class="container mx-auto px-6 py-10">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- SIDEBAR -->
            <%- include('../partials/admin-sidebar', { active: 'dashboard' }) %>

                <!-- MAIN CONTENT -->
                <main class="flex-1 space-y-10">

                    <!-- STATS GRID -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Doanh thu -->
                        <div class="glass p-8 rounded-[2.5rem] border-l-8 border-blue-500">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Tổng doanh
                                thu
                            </p>
                            <h3 class="text-3xl font-black text-slate-900">
                                <%= stats.totalRevenue.toLocaleString('vi-VN') %>đ
                            </h3>
                            <p class="text-xs font-bold text-emerald-500 mt-2">↑ <%= stats.revenueGrowth %>% so với
                                    tháng
                                    trước</p>
                        </div>
                        <!-- Đơn hàng -->
                        <div class="glass p-8 rounded-[2.5rem] border-l-8 border-indigo-500">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Đơn hàng mới
                            </p>
                            <h3 class="text-3xl font-black text-slate-900">
                                <%= stats.totalOrders %>
                            </h3>
                            <span
                                class="inline-block px-3 py-1 bg-indigo-50 text-indigo-600 text-[10px] font-black rounded-lg mt-2 uppercase">
                                <%= stats.pendingOrders %> Chờ xử lý
                            </span>
                        </div>
                        <!-- Sản phẩm -->
                        <div class="glass p-8 rounded-[2.5rem] border-l-8 border-emerald-500">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Kho sản phẩm
                            </p>
                            <h3 class="text-3xl font-black text-slate-900">
                                <%= stats.totalProducts %>
                            </h3>
                            <p class="text-xs font-bold text-rose-500 mt-2">⚠️ <%= stats.lowStockProducts %> sản phẩm
                                    sắp
                                    hết</p>
                        </div>
                        <!-- Users -->
                        <div class="glass p-8 rounded-[2.5rem] border-l-8 border-slate-800">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Khách hàng
                            </p>
                            <h3 class="text-3xl font-black text-slate-900">
                                <%= stats.totalUsers %>
                            </h3>
                            <p class="text-xs font-bold text-slate-500 mt-2">+<%= stats.newUsersThisMonth %> trong tháng
                                    này
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                        <!-- RECENT ORDERS -->
                        <div class="glass p-10 rounded-[3rem]">
                            <div class="flex items-center justify-between mb-8">
                                <h2 class="text-xl font-bold">Đơn hàng mới nhất</h2>
                                <a href="/admin/don-hang"
                                    class="text-xs font-black text-blue-600 uppercase tracking-widest hover:underline">Tất
                                    cả →</a>
                            </div>
                            <div class="space-y-4">
                                <% recentOrders.forEach(order=> { %>
                                    <div
                                        class="flex items-center justify-between p-5 rounded-[1.5rem] bg-slate-50 hover:bg-white border border-transparent hover:border-slate-100 transition-all">
                                        <div>
                                            <p class="text-xs font-black text-slate-900">#<%= order.orderCode %>
                                            </p>
                                            <p class="text-[10px] text-slate-400 font-bold">
                                                <%= order.user?.lastName %>
                                                    <%= order.user?.firstName %>
                                            </p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-sm font-black text-blue-600">
                                                <%= order.totalAmount.toLocaleString('vi-VN') %>đ
                                            </p>
                                            <span
                                                class="text-[9px] font-black uppercase tracking-tighter text-slate-400">
                                                <%= order.orderStatus %>
                                            </span>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>

                        <!-- TOP PRODUCTS -->
                        <div class="glass p-10 rounded-[3rem]">
                            <div class="flex items-center justify-between mb-8">
                                <h2 class="text-xl font-bold">Top bán chạy</h2>
                            </div>
                            <div class="space-y-4">
                                <% topProducts.forEach(p=> { %>
                                    <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50/50">
                                        <div class="w-12 h-12 bg-white p-2 rounded-xl">
                                            <img src="<%= p.thumbnail %>" class="w-full h-full object-contain">
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-xs font-bold text-slate-900 line-clamp-1">
                                                <%= p.name %>
                                            </p>
                                            <p class="text-[10px] text-slate-400 font-black uppercase tracking-[1px]">
                                                <%= p.brand %>
                                            </p>
                                        </div>
                                        <div class="px-3 py-1 bg-white rounded-lg border border-slate-100">
                                            <p class="text-[11px] font-bold text-slate-700">Đã bán: <span
                                                    class="text-blue-600 font-black">
                                                    <%= p.sold %>
                                                </span></p>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>
                    </div>

                    <!-- REVENUE CHART -->
                    <div class="glass p-10 rounded-[3rem] mt-10">
                        <h2 class="text-xl font-bold mb-8">Xu hướng doanh thu</h2>
                        <canvas id="revenueChart" height="100"></canvas>
                    </div>
                </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const ctx = document.getElementById('revenueChart');
            if (ctx) {
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['T3', 'T4', 'T5', 'T6', 'T7', 'T8'],
                        datasets: [{
                            label: 'Doanh thu',
                            data: [15, 25, 22, 35, 30, 48].map(v => v * 1000000),
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 4,
                            pointRadius: 6,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#3b82f6',
                            pointBorderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0,0,0,0.05)' },
                                ticks: {
                                    callback: function (value) {
                                        return (value / 1000000) + 'M';
                                    }
                                }
                            },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }
        });
    </script>