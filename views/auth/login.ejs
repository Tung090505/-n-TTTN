<% layout('layouts/main') %>
    <div class="min-h-[80vh] flex items-center justify-center py-12 px-6">
        <div class="w-full max-w-md">
            <div class="glass p-10 rounded-[3rem] shadow-2xl border border-white/40">

                <!-- Header -->
                <div class="text-center mb-10">
                    <h1 class="text-4xl font-black text-slate-900 mb-2">Xin chào! 👋</h1>
                    <p class="text-slate-500">Đăng nhập để trải nghiệm TechStore tốt nhất.</p>
                </div>

                <!-- Global Error Message -->
                <div id="global-error"
                    class="hidden mb-6 p-4 rounded-2xl bg-red-50 border border-red-100 flex items-start gap-3">
                    <span class="text-red-500 mt-0.5">⚠️</span>
                    <p class="text-sm text-red-600 font-bold leading-tight" id="global-error-msg"></p>
                </div>

                <!-- Form -->
                <form action="/api/auth/login" method="POST" id="login-form" class="space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Email</label>
                        <input type="email" name="email" required placeholder="name@example.com"
                            class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all transition-all input-focus">
                    </div>

                    <div>
                        <div class="flex items-center justify-between mb-2 ml-1">
                            <label class="text-sm font-bold text-slate-700">Mật khẩu</label>
                            <a href="#" class="text-xs text-blue-600 hover:underline">Quên mật khẩu?</a>
                        </div>
                        <input type="password" name="password" required placeholder="••••••••"
                            class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all input-focus">
                    </div>

                    <div class="flex items-center gap-3 ml-1">
                        <input type="checkbox" id="remember"
                            class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                        <label for="remember" class="text-sm text-slate-600 cursor-pointer">Ghi nhớ đăng nhập</label>
                    </div>

                    <button type="submit"
                        class="w-full py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-xl shadow-blue-500/20 transition-all active:scale-95">
                        Đăng Nhập
                    </button>
                </form>

                <!-- Footer -->
                <div class="mt-10 pt-10 border-t border-slate-200 text-center">
                    <p class="text-slate-500">Chưa có tài khoản?
                        <a href="/dang-ky" class="text-blue-600 font-bold hover:underline">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('login-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            // Reset styles and messages
            document.querySelectorAll('.input-error-msg').forEach(el => el.remove());
            document.querySelectorAll('.input-focus').forEach(el => el.classList.remove('border-red-500', 'ring-red-500/20'));

            try {
                const res = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    window.location.href = '/';
                } else {
                    if (result.errors) {
                        result.errors.forEach(err => {
                            const input = document.querySelector(`[name="${err.field}"]`);
                            if (input) {
                                input.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                                const errorDiv = document.createElement('p');
                                errorDiv.className = 'text-[10px] text-red-500 font-bold mt-1 ml-1 input-error-msg';
                                errorDiv.innerText = '× ' + err.message;
                                input.parentNode.appendChild(errorDiv);
                            }
                        });
                    } else {
                        showToast(result.message || 'Email hoặc mật khẩu không chính xác', 'error');
                    }
                }
            } catch (err) {
                showToast('Lỗi kết nối máy chủ! Vui lòng thử lại.', 'error');
            }
        });
    </script>