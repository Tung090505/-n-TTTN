<nav class="sticky top-0 z-[100] glass border-b border-white/20">
    <div class="container mx-auto px-6">
        <div class="flex items-center justify-between h-20">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 group">
                <div
                    class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white text-xl shadow-lg shadow-blue-500/20 group-hover:rotate-12 transition-transform">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75">
                        </path>
                    </svg>
                </div>
                <span class="text-2xl font-black tracking-tighter text-slate-900">TECH<span
                        class="text-blue-600">STORE</span></span>
            </a>

            <!-- Search Bar -->
            <div class="hidden md:flex flex-1 max-w-md mx-10">
                <form action="/san-pham" method="GET" class="w-full relative group">
                    <input type="text" name="search" placeholder="Tìm laptop, linh kiện..."
                        class="w-full bg-slate-100/50 border-none rounded-2xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all outline-none text-sm">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>
                </form>
            </div>

            <!-- Links & User -->
            <div class="flex items-center gap-6">
                <a href="/san-pham"
                    class="hidden lg:block text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Sản
                    phẩm</a>

                <a href="/build-pc"
                    class="hidden lg:flex items-center gap-1.5 text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                        </path>
                    </svg>
                    Build PC
                </a>

                <div class="h-6 w-px bg-slate-200 hidden lg:block"></div>

                <% if (user) { %>
                    <!-- Cart Icon -->
                    <a href="/gio-hang" class="relative group">
                        <div
                            class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-xl group-hover:bg-blue-50 group-hover:text-blue-600 transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 0a2 2 0 100 4 2 2 0 000-4z">
                                </path>
                            </svg>
                        </div>
                        <span id="cart-count"
                            class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center border-2 border-white">0</span>
                    </a>

                    <!-- User Menu -->
                    <div class="relative group">
                        <button
                            class="flex items-center gap-3 p-1.5 rounded-2xl hover:bg-slate-100 transition-all border border-transparent hover:border-slate-200">
                            <div
                                class="w-9 h-9 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center text-white font-bold text-sm">
                                <%= user.firstName.charAt(0) %>
                            </div>
                            <span class="hidden sm:block text-sm font-bold text-slate-700">
                                <%= user.firstName %>
                            </span>
                        </button>

                        <!-- Dropdown -->
                        <div
                            class="absolute right-0 top-full mt-2 w-48 bg-white rounded-2xl shadow-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all py-2 z-50">
                            <% if (user.role==='admin' ) { %>
                                <a href="/admin/dashboard"
                                    class="flex items-center gap-2 px-4 py-2.5 text-sm text-blue-600 hover:bg-blue-50 font-bold transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z">
                                        </path>
                                    </svg>
                                    Dashboard Admin
                                </a>
                                <% } %>
                                    <a href="/tai-khoan/don-hang"
                                        class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600 font-medium transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4">
                                            </path>
                                        </svg>
                                        Đơn hàng
                                    </a>
                                    <a href="/tai-khoan"
                                        class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600 font-medium transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z">
                                            </path>
                                        </svg>
                                        Hồ sơ
                                    </a>
                                    <div class="h-px bg-slate-100 mx-2 my-1"></div>
                                    <button onclick="logout()"
                                        class="w-full flex items-center gap-2 text-left px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 font-medium transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                                            </path>
                                        </svg>
                                        Đăng xuất
                                    </button>
                        </div>
                    </div>
                    <% } else { %>
                        <div class="flex items-center gap-3">
                            <a href="/dang-nhap"
                                class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Đăng
                                nhập</a>
                            <a href="/dang-ky"
                                class="px-5 py-2.5 bg-slate-900 text-white text-sm font-bold rounded-xl hover:bg-blue-600 transition-all shadow-md active:scale-95">Tham
                                gia</a>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>
</nav>

<!-- Flash Messages -->
<% if (success) { %>
    <div class="fixed top-24 right-6 z-[110] animate-fade-in-up">
        <div
            class="bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 border border-emerald-400/20">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-bold">
                <%= success %>
            </span>
        </div>
    </div>
    <% } %>
        <% if (error) { %>
            <div class="fixed top-24 right-6 z-[110] animate-fade-in-up">
                <div
                    class="bg-red-500 text-white px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 border border-red-400/20">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="font-bold">
                        <%= error %>
                    </span>
                </div>
            </div>
            <% } %>

                <script>
                    async function logout() {
                        await fetch('/api/auth/logout', { method: 'POST' });
                        window.location.href = '/dang-nhap';
                    }

                    async function loadCartCount() {
                        try {
                            const res = await fetch('/api/cart');
                            const data = await res.json();
                            if (data.success) {
                                document.getElementById('cart-count').innerText = data.data.cart.totalItems;
                            }
                        } catch (err) { }
                    }
  <% if (user) { %> loadCartCount(); <% } %>
                </script>