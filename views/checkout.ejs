<% layout('layouts/main') %>
    <div class="container mx-auto px-6 py-10">
        <div class="flex flex-col lg:flex-row gap-12">

            <!-- LEFT: FORM THÔNG TIN -->
            <div class="lg:col-span-8">
                <div class="glass p-10 rounded-[3rem] shadow-xl">
                    <h2 class="text-3xl font-black mb-8">Thông Tin Giao Hàng</h2>

                    <form id="checkout-form" class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Số điện thoại</label>
                                <input type="tel" name="shippingAddress.phone" required placeholder="0901234567"
                                    class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Đường / Số nhà</label>
                                <input type="text" name="shippingAddress.street" required placeholder="123 Đường ABC"
                                    class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Xã/Phường</label>
                                <input type="text" name="shippingAddress.ward" required
                                    class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Quận/Huyện</label>
                                <input type="text" name="shippingAddress.district" required
                                    class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Tỉnh/Thành phố</label>
                                <input type="text" name="shippingAddress.city" required
                                    class="w-full px-6 py-4 rounded-2xl bg-slate-100 border-none outline-none focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all">
                            </div>
                        </div>

                        <div class="h-px bg-slate-100 my-8"></div>

                        <div>
                            <h3 class="text-xl font-bold mb-6">Phương Thức Thanh Toán</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <label
                                    class="p-6 rounded-2xl border-2 border-blue-600 bg-blue-50 cursor-pointer flex items-center gap-4">
                                    <input type="radio" name="paymentMethod" value="cod" checked
                                        class="w-5 h-5 text-blue-600">
                                    <div>
                                        <p class="font-bold text-slate-900">Thanh toán khi nhận hàng (COD)</p>
                                        <p class="text-xs text-slate-500">Thanh toán bằng tiền mặt khi giao hàng</p>
                                    </div>
                                </label>
                                <label
                                    class="p-6 rounded-2xl border-2 border-slate-100 hover:border-blue-200 cursor-pointer flex items-center gap-4 transition-all">
                                    <input type="radio" name="paymentMethod" value="vnpay"
                                        class="w-5 h-5 text-blue-600">
                                    <div>
                                        <p class="font-bold text-slate-900">Chuyển khoản / VNPAY</p>
                                        <p class="text-xs text-slate-500">Thanh toán qua cổng VNPAY an toàn</p>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full py-5 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-3xl shadow-xl shadow-blue-500/20 transition-all text-xl mt-10">
                            Xác Nhận Đặt Hàng ⚡
                        </button>
                    </form>
                </div>
            </div>

            <!-- RIGHT: ORDER SUMMARY -->
            <div class="lg:col-span-4">
                <div class="glass p-8 rounded-[3rem] sticky top-28 shadow-xl">
                    <h3 class="text-xl font-bold mb-6">Đơn hàng của bạn</h3>
                    <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2 mb-6">
                        <% cart.items.forEach(item=> { %>
                            <div class="flex items-center gap-4">
                                <div class="w-16 h-16 bg-slate-100 rounded-xl p-2 shrink-0">
                                    <img src="<%= item.product.thumbnail %>" class="w-full h-full object-contain">
                                </div>
                                <div class="flex-grow">
                                    <h4 class="text-sm font-bold text-slate-800 line-clamp-1">
                                        <%= item.product.name %>
                                    </h4>
                                    <p class="text-[11px] text-slate-400">SL: <%= item.quantity %> x <%=
                                                item.price.toLocaleString('vi-VN') %>đ</p>
                                </div>
                                <span class="text-sm font-bold text-slate-900">
                                    <%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ
                                </span>
                            </div>
                            <% }) %>
                    </div>

                    <div class="h-px bg-slate-100 mb-6"></div>

                    <div class="space-y-3">
                        <div class="flex justify-between text-sm text-slate-500">
                            <span>Tạm tính:</span>
                            <span class="font-bold text-slate-800">
                                <%= cart.totalAmount.toLocaleString('vi-VN') %>đ
                            </span>
                        </div>
                        <div class="flex justify-between text-sm text-slate-500">
                            <span>Phí ship:</span>
                            <span class="font-bold text-emerald-500">Miễn phí</span>
                        </div>
                        <div class="flex justify-between text-xl font-black pt-4 border-t border-slate-100">
                            <span>Tổng cộng:</span>
                            <span class="text-blue-600">
                                <%= cart.totalAmount.toLocaleString('vi-VN') %>đ
                            </span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        document.getElementById('checkout-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = {
                shippingAddress: {
                    phone: formData.get('shippingAddress.phone'),
                    street: formData.get('shippingAddress.street'),
                    ward: formData.get('shippingAddress.ward'),
                    district: formData.get('shippingAddress.district'),
                    city: formData.get('shippingAddress.city'),
                },
                paymentMethod: formData.get('paymentMethod')
            };

            try {
                const res = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    showToast('Đặt hàng thành công! Mã đơn: ' + result.data.order.orderCode, 'success');
                    setTimeout(() => window.location.href = '/tai-khoan/don-hang', 2000);
                } else {
                    showToast(result.message || 'Lỗi đặt hàng', 'error');
                }
            } catch (err) { showToast('Lỗi kết nối máy chủ!', 'error'); }
        });
    </script>