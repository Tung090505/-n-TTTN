<% layout('layouts/main') %>
    <div class="space-y-20">

        <!-- HERO SECTION: ULTRA PREMIUM -->
        <section class="container mx-auto px-6 mt-8">
            <div
                class="relative rounded-[2rem] overflow-hidden bg-gradient-to-r from-blue-700 to-indigo-800 text-white min-h-[500px] flex items-center shadow-2xl">
                <!-- Background Animated Shapes -->
                <div class="absolute inset-0 z-0 overflow-hidden">
                    <div
                        class="absolute top-[-20%] left-[-10%] w-[50%] h-[60%] bg-blue-500/30 rounded-full blur-[100px] animate-pulse">
                    </div>
                    <div class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[70%] bg-indigo-500/30 rounded-full blur-[120px] animate-pulse"
                        style="animation-delay: 2s"></div>
                </div>

                <div
                    class="container mx-auto px-10 md:px-16 relative z-10 flex flex-col md:flex-row items-center justify-between">
                    <div class="max-w-2xl py-12">
                        <span
                            class="inline-block px-4 py-1.5 mb-6 text-sm font-bold tracking-wider text-blue-100 uppercase bg-white/10 rounded-full border border-white/20 backdrop-blur-sm animate-fade-in-up">
                            CHÍNH HÃNG UY TÍN
                        </span>
                        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight animate-fade-in-up uppercase font-heading"
                            style="animation-delay: 0.1s">
                            Xây Dựng Cấu Hình <br>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-blue-200">Chuẩn
                                Phong Cách</span>
                        </h1>
                        <p class="text-lg text-blue-100/80 mb-10 max-w-xl leading-relaxed animate-fade-in-up font-medium"
                            style="animation-delay: 0.2s">
                            Hàng ngàn linh kiện chính hãng sẵn sàng. Tự do sáng tạo sức mạnh, hỗ trợ lắp ráp chuyên
                            nghiệp và giao hàng siêu tốc.
                        </p>
                        <div class="flex flex-wrap gap-4 animate-fade-in-up" style="animation-delay: 0.3s">
                            <a href="/san-pham"
                                class="px-8 py-4 bg-white hover:bg-slate-50 text-blue-700 font-bold rounded-xl transition-all shadow-lg active:scale-95">
                                Mua Ngay
                            </a>
                            <a href="/build-pc"
                                class="px-8 py-4 bg-blue-600/50 hover:bg-blue-600 text-white font-bold rounded-xl transition-all border border-blue-400/30 backdrop-blur-sm active:scale-95 flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                </svg> Try AI Builder
                            </a>
                        </div>
                    </div>

                    <!-- Floating Graphic -->
                    <div class="hidden lg:block relative z-10 animate-fade-in-up p-8" style="animation-delay: 0.4s">
                        <img src="https://images.unsplash.com/photo-1587202372775-e229f172b9d7?q=80&w=600&auto=format&fit=crop"
                            alt="Gaming PC"
                            class="w-96 h-96 rounded-full drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] transform -rotate-12 hover:rotate-0 transition-transform duration-700 hover:scale-105 object-cover object-center border-4 border-white/10">
                    </div>
                </div>
            </div>
        </section>

        <!-- FEATURES: TRUST & QUALITY -->
        <section class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div
                    class="bg-white border border-slate-100 shadow-sm p-6 rounded-2xl flex items-start gap-4 hover:shadow-md transition-shadow">
                    <div
                        class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z">
                            </path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-800 mb-1">Chính Hãng 100%</h3>
                        <p class="text-slate-500 text-sm">TechStore cam kết mọi sản phẩm bán ra đều đầy đủ hóa đơn,
                            chứng từ.</p>
                    </div>
                </div>
                <div
                    class="bg-white border border-slate-100 shadow-sm p-6 rounded-2xl flex items-start gap-4 hover:shadow-md transition-shadow">
                    <div
                        class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-800 mb-1">Giao Hàng Thần Tốc</h3>
                        <p class="text-slate-500 text-sm">Hỗ trợ lắp ráp cài đặt và giao hàng nội thành siêu tốc 2h.</p>
                    </div>
                </div>
                <div
                    class="bg-white border border-slate-100 shadow-sm p-6 rounded-2xl flex items-start gap-4 hover:shadow-md transition-shadow">
                    <div
                        class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3 18v-6a9 9 0 0118 0v6M3 18a3 3 0 003 3h1a2 2 0 002-2v-4a2 2 0 00-2-2H4m17 2a3 3 0 00-3 3h-1a2 2 0 00-2-2v-4a2 2 0 002-2h3">
                            </path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-800 mb-1">Hỗ Trợ Kỹ Thuật 24/7</h3>
                        <p class="text-slate-500 text-sm">Đội ngũ chuyên gia luôn sẵn sàng giải đáp và khắc phục sự cố.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CATEGORIES: SMART SELECTION -->
        <section class="container mx-auto px-6 py-10 border-t border-slate-100">
            <div class="flex items-end justify-between mb-8">
                <div>
                    <h2 class="text-2xl font-bold mb-1 text-slate-800 uppercase tracking-tight">Danh Mục Linh Kiện</h2>
                    <p class="text-slate-500 text-sm">Đầy đủ mọi linh kiện để lắp ráp bộ PC mơ ước</p>
                </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <% const svgIcon=(path)=> `<svg class="w-8 h-8 text-current" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="${path}"></path>
                    </svg>`;
                    const cats=[
                    { name: 'Laptop', slug: 'laptop', icon: svgIcon(`M21 16V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8M3 16h18a2 2
                    0 012 2v2a2 2 0 01-2 2H3a2 2 0 01-2-2v-2a2 2 0 012-2z`), color: 'text-indigo-600' },
                    { name: 'CPU', slug: 'cpu', icon: svgIcon(`M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7
                    19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z`), color:
                    'text-blue-600' },
                    { name: 'VGA / GPU', slug: 'gpu', icon: svgIcon(`M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4
                    10h16v11H4V10z`), color: 'text-emerald-600' },
                    { name: 'RAM', slug: 'ram', icon: svgIcon(`M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002
                    2h10a2 2 0 002-2V8m-9 4h4`), color: 'text-orange-600' },
                    { name: 'SSD / HDD', slug: 'storage', icon: svgIcon(`M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0
                    2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4`),
                    color: 'text-rose-600' },
                    { name: 'Màn hình', slug: 'monitor', icon: svgIcon(`M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5
                    17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z`), color: 'text-cyan-600' }
                    ];
                    %>
                    <% cats.forEach(c=> { %>
                        <a href="/san-pham?category=<%= c.slug %>"
                            class="group bg-white border border-slate-100 hover:border-blue-300 rounded-2xl p-6 text-center transition-all hover:shadow-lg hover:shadow-blue-500/5 hover:-translate-y-1">
                            <div
                                class="w-16 h-16 mx-auto rounded-full bg-slate-50 flex items-center justify-center <%= c.color %> mb-4 group-hover:scale-110 transition-transform">
                                <%- c.icon %>
                            </div>
                            <span class="font-bold text-sm text-slate-700 group-hover:text-blue-600 transition-colors">
                                <%= c.name %>
                            </span>
                        </a>
                        <% }) %>
            </div>
        </section>

        <!-- FEATURED PRODUCTS -->
        <section id="featured"
            class="container mx-auto px-6 py-10 bg-slate-50/50 mt-10 rounded-t-[3rem] border-t border-slate-100">
            <div class="flex flex-col md:flex-row items-baseline justify-between mb-8 gap-4">
                <h2 class="text-2xl font-bold uppercase text-slate-800 tracking-tight flex items-center gap-2">
                    <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z">
                        </path>
                    </svg>
                    Sản Phẩm Đang Hot
                </h2>
                <a href="/san-pham"
                    class="text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors flex items-center gap-1">Xem
                    tất cả <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg></a>
            </div>
            <div id="featured-products" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Loading Skeleton -->
                <% for(let i=0; i<4; i++) { %>
                    <div class="bg-white rounded-3xl p-6 border border-slate-100 animate-pulse">
                        <div class="w-full h-52 bg-slate-100 rounded-2xl mb-6"></div>
                        <div class="h-4 bg-slate-100 rounded-full w-2/3 mb-3"></div>
                        <div class="h-4 bg-slate-100 rounded-full w-full mb-6"></div>
                        <div class="flex justify-between items-center">
                            <div class="h-6 bg-slate-100 rounded-full w-1/3"></div>
                            <div class="w-10 h-10 bg-slate-100 rounded-xl"></div>
                        </div>
                    </div>
                    <% } %>
            </div>
        </section>

        <!-- NEWSLETTER -->
        <section class="container mx-auto px-6 py-16">
            <div
                class="p-10 md:p-16 rounded-[2rem] bg-gradient-to-r from-blue-700 to-indigo-800 overflow-hidden relative shadow-2xl">
                <div class="absolute inset-0 z-0">
                    <svg class="absolute right-0 bottom-0 opacity-10 w-96 h-96 transform translate-x-1/4 translate-y-1/4"
                        fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0L0 12l12 12 12-12L12 0z" />
                    </svg>
                </div>
                <div class="relative z-10 max-w-2xl mx-auto text-center">
                    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Đăng ký nhận thông tin khuyến mãi</h2>
                    <p class="text-blue-100 mb-8 max-w-lg mx-auto">Cập nhật sớm nhất các chương trình xả kho thiết bị
                        công nghệ, giảm giá sốc từ TechStore.</p>
                    <form class="flex flex-col sm:flex-row gap-3">
                        <input type="email" placeholder="Nhập địa chỉ email..."
                            class="flex-1 px-6 py-4 rounded-xl bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-4 focus:ring-blue-400/50 shadow-inner">
                        <button
                            class="px-8 py-4 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl transition-all shadow-md active:scale-95 whitespace-nowrap">
                            Đăng Ký Ngay
                        </button>
                    </form>
                </div>
            </div>
        </section>

    </div>

    <script>
        async function loadFeatured() {
            try {
                const res = await fetch('/api/products/featured');
                const json = await res.json();
                if (!json.success) return;

                const container = document.getElementById('featured-products');
                container.innerHTML = json.data.products.map(p => `
        <article class="product-card group bg-white rounded-2xl p-5 border border-slate-100 shadow-sm hover:shadow-lg transition-all relative flex flex-col h-full hover:border-blue-200">
          <div class="absolute top-4 right-4 z-20">
            <button class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </button>
          </div>
          
          <a href="/san-pham/${p.slug}" class="block mb-6 overflow-hidden rounded-2xl bg-slate-50 p-4">
            <img src="${p.thumbnail}" alt="${p.name}" class="w-full h-48 object-contain mix-blend-multiply group-hover:scale-110 transition-transform duration-500">
          </a>

          <div class="flex-grow">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 rounded-md bg-slate-100 text-[10px] font-bold text-slate-500 uppercase tracking-wider">${p.brand}</span>
              ${p.isNewArrival ? '<span class="px-2 py-0.5 rounded-md badge-new text-[10px] font-bold text-white uppercase tracking-wider">MỚI</span>' : ''}
            </div>
            <h3 class="font-bold text-slate-900 leading-snug mb-3 group-hover:text-blue-600 transition-colors line-clamp-2 min-h-[3rem]">
              <a href="/san-pham/${p.slug}">${p.name}</a>
            </h3>
            
            <div class="flex items-center gap-2 mb-4">
               <div class="flex text-yellow-400 text-xs">
                  ${'★'.repeat(Math.round(p.rating || 0))}${'☆'.repeat(5 - Math.round(p.rating || 0))}
               </div>
               <span class="text-slate-400 text-[11px]">(${p.numReviews || 0} nhận xét)</span>
            </div>
          </div>

          <div class="flex items-center justify-between pt-4 mt-auto border-t border-slate-50">
            <div>
              ${p.salePrice && p.salePrice < p.price ? `<p class="text-slate-400 line-through text-xs">${String((p.price)).replace(/(.)(?=(\d{3})+$)/g, '$1.')}đ</p>` : ''}
              <p class="text-red-600 font-bold text-lg leading-none">${String((p.salePrice || p.price)).replace(/(.)(?=(\d{3})+$)/g, '$1.')}đ</p>
            </div>
            <button onclick="addToCart('${p._id}')" class="w-10 h-10 rounded-xl border border-blue-600 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all active:scale-95" title="Thêm vào giỏ">
               <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 0a2 2 0 100 4 2 2 0 000-4z"></path></svg>
            </button>
          </div>
        </article>
      `).join('');
            } catch (err) { console.error(err); }
        }

        async function addToCart(id) {
            try {
                const res = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: id, quantity: 1 })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Đã thêm sản phẩm vào giỏ hàng!', 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Vui lòng đăng nhập!', 'error');
                }
            } catch (err) { showToast('Lỗi thêm sản phẩm', 'error'); }
        }

        loadFeatured();
    </script>